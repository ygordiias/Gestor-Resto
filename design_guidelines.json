      "secondary": "bg-transparent border border-[#3E2723] text-[#3E2723] hover:bg-[#3E2723] hover:text-[#F5F1E6] dark:border-[#E6DCC3] dark:text-[#E6DCC3] dark:hover:bg-[#E6DCC3] dark:hover:text-[#1A120B] font-serif uppercase tracking-widest transition-all duration-300",
