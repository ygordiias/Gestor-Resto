      "base": "bg-transparent border-b-2 border-[#D7CCC8] dark:border-[#4E342E] focus:border-[#D4AF37] outline-none px-0 py-2 transition-colors duration-300 placeholder:text-[#8D6E63] dark:placeholder:text-[#A1887F]"
    }
