  "instructions_to_main_agent": [
    "1. INSTALL FONTS: Add the Google Fonts import to index.css immediately.",
    "2. CONFIGURE TAILWIND: Update tailwind.config.js with the custom colors (parchment, biblical-gold, etc.) and font families.",
    "3. THEME IMPLEMENTATION: Use the 'parchment' color as the main background for Light Mode. Do not use pure white.",
    "4. COMPONENT OVERRIDES: Heavily customize Shadcn components. Remove default borders and replace with 'border-b' or 'gold-trim' styles where appropriate.",
    "5. LAYOUT: Use the 'Bento' grid for the main dashboard. Ensure high contrast for the Kitchen/Bar panels (large text).",
    "6. KANBAN BOARDS: For Kitchen/Bar, use a high-contrast, card-based layout. Status colors should be muted (Olive Green for Done, Terracotta for Pending) to fit the theme.",
    "7. MOBILE: Ensure all touch targets are at least 44px. The 'Order Creation' flow must be thumb-friendly."
  ],
  "UNIVERSAL_GUIDELINES_FOR_MAIN_AGENT": [
    "Avoid 'AI Slop' - no generic gradients or default Shadcn looks.",
    "Use 'Cinzel' for all major headings to establish the Biblical theme.",
    "Use 'DM Sans' for all data tables and small text for readability.",
    "Ensure the 'Gold' color is used sparingly as an accent, not a background.",
    "All interactive elements must have 'data-testid'.",
    "Use 'sonner' for toasts.",
    "Do not use 'Inter' font."
  ]
